{
  "version": 8,
  "name": "Topo",
  "metadata": {
    "maputnik:renderer": "mlgljs"
  },
  "sources": {
    "sg-topo": {
      "type": "raster",
      "tiles": [
        "https://map.skitourenguru.com/AP_SG_TOPO_MINI_PRIVATE.tms?x={x}&y={y}&z={z}"
      ],
      "minzoom": 0,
      "maxzoom": 24,
      "scheme": "xyz",
      "tileSize": 128
    },
    "sg-bulletins": {
      "type": "geojson",
      "data": "https://www.skitourenguru.com/calc_data2/json/Alps_Current_Bulletin_4326.json"
